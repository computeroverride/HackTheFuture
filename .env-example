# ============================================================
# ADAM-6717
# ============================================================

ADAM_IP=10.0.0.1
ADAM_PORT=5020
ADAM_SLAVE_ID=1

# DI2 = button
DI2_ADDRESS=2

# DO0 = fan relay
DO0_ADDRESS=16

# AI2 = temperature sensor voltage
AI2_ADDRESS=34

# DO1 = buzzer
DO1_ADDRESS=17


# ============================================================
# LOOP SETTINGS
# ============================================================

POLL_INTERVAL_SECONDS=0.05
DEBOUNCE_SECONDS=0.20
PUBLISH_HEARTBEAT_SECONDS=3.0


# ============================================================
# TEMPERATURE / BUZZER SETTINGS
#
# Based on your test:
# Room AI2 ≈ 2.65 V
# Warm AI2 ≈ 2.86 V
# ============================================================

BUZZER_ON_VOLTAGE=2.85
BUZZER_OFF_VOLTAGE=2.80


# ============================================================
# EDGEHUB
# ============================================================

EDGEHUB_ENABLED=true

# Copy these from your EdgeHub SCADA device connection settings.
EDGEHUB_NODE_ID=
EDGEHUB_SAS_TOKEN=

# Logical child device that will contain your tags.
EDGEHUB_DEVICE_ID=ADAM6717_IO

EDGEHUB_PROTOCOL_HEARTBEAT_SECONDS=60