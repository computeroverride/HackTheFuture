# ============================================================
# ADAM-6717 connection
# ============================================================
ADAM_IP=11.0.0.1
ADAM_PORT=5020
ADAM_SLAVE_ID=1

# ============================================================
# Physical input/output mapping
# Change these to match your ADAM/EdgeHub setup.
# Defaults assume:
#   DI0 = camera/photoelectric sensor
#   DI1 = end sensor
#   DI2 = reset/start button
#   DO0 = conveyor motor relay/enable
#   DO1 = servo trigger to Arduino/ESP32
#   DO2 = buzzer
#   DO3 = fan
# Many ADAM units map DO0 as coil 16, DO1 as 17, etc.
# ============================================================
DI_CAMERA_SENSOR_ADDRESS=0
DI_END_SENSOR_ADDRESS=1
DI_BUTTON_ADDRESS=2

DO_CONVEYOR_ADDRESS=16
DO_SERVO_TRIGGER_ADDRESS=17
DO_BUZZER_ADDRESS=18
DO_FAN_ADDRESS=19

# Optional temperature analog input
TEMPERATURE_ENABLED=false
AI_TEMPERATURE_ADDRESS=0
TEMP_FAN_ON_C=40
TEMP_FAN_OFF_C=35
TEMP_DANGER_C=60

# ============================================================
# Timing — tune these on your actual conveyor
# ============================================================
POLL_INTERVAL_SECONDS=0.05
DEBOUNCE_SECONDS=0.20
PUBLISH_HEARTBEAT_SECONDS=3.0

# Time from camera sensor to servo pusher
REJECT_DELAY_SECONDS=3.5

# Time from camera sensor to end sensor
END_DELAY_SECONDS=5.0

# Matching tolerance around expected end time
END_MATCH_TOLERANCE_SECONDS=0.8

# ADAM DO pulse duration for Arduino/ESP32 servo trigger
SERVO_TRIGGER_PULSE_SECONDS=0.20
BUZZER_PULSE_SECONDS=0.40

# ============================================================
# Webcam + ML mode
# ML_MODE options:
#   fake_alternate  = every Nth pill is faulty; best for hardware timing test
#   manual          = asks you to type ok/faulty in terminal
#   brightness      = rough OpenCV brightness heuristic; not a real model
# ============================================================
CAMERA_INDEX=0
CAMERA_BURST_COUNT=3
CAMERA_BURST_GAP_SECONDS=0.10
ML_MODE=fake_alternate
FAKE_FAULT_EVERY_N=3

# ============================================================
# Telegram optional
# ============================================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# EdgeHub — Python data gateway only
# ============================================================
EDGEHUB_ENABLED=true
EDGEHUB_NODE_ID=
EDGEHUB_IOTHUB_HOST=
EDGEHUB_SAS_TOKEN=""
EDGEHUB_USE_X509=false
EDGEHUB_DEVICE_ID=ADAM6717_IO
EDGEHUB_PROTOCOL_HEARTBEAT_SECONDS=60
